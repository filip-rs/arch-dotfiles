// LAPTOP CONFIG


[{
    "layer": "top",
    "output": "eDP-1",
    "position": "bottom",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 0,
    "modules-left": ["clock", "custom/weather", "hyprland/workspaces"],
    //"modules-center": ["hyprland/window"],
    "modules-right": ["tray","pulseaudio","pulseaudio#microphone","backlight","battery","custom/laptopwlogout"],
    "hyprland/window": {
        "format": "{}"
    },

   "hyprland/workspaces": {
        "disable-scroll": true,
        "on-scroll-up": "hyprctl dispatch workspace -1",
        "on-scroll-down": "hyprctl dispatch workspace +1",
		"format": "{name}: {windows}",
		"on-click": "activate",
		"format-icons": {
			"urgent": "ο¹Σ",
			"active": "",
			"default": ""
		},

    	"persistent-workspaces": {
    	         "*": 5
        },

        "window-rewrite-default": "σ±™Μ",
	    "window-rewrite": {
		    "title<.*youtube.*>": "οÖΣ", // Windows whose titles contain "youtube"
		    "class<firefox>": "οâ©", // Windows whose classes are "firefox"
		    "class<none>": "r", // Windows whose classes are "firefox"
		    "class<librewolf>": "σΑàΙ", // Windows whose classes are "firefox"
		    "class<librewolf> title<.*github.*>": "ο³™", // Windows whose class is "firefox" and title contains "github". Note that "class" always comes first.
		    "alacritty": "νûï", // Windows that contain "foot" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
		    "ghostty": "νûï", 
            "thunar": "σ±ßΕ", // Windows that contain "foot" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
		    "code": "σΑ®û",
		    "slack": "νΔΛ",
		    "youtube-music": "σΑéÜ",
            "notion": "νΓà",
		    "title<.* - (.*) - VSCodium>": "codium $1"  // captures part of the window title and formats it into output
	    }
    },

    "custom/power_profile":{
        //shows the current power profile and switches to next on click
        "exec": "asusctl profile -p | sed s:'Active profile is'::",
        "interval": 30,
        "format": "σΑàê{}", 
        "on-click": "asusctl profile -n; pkill -SIGRTMIN+8 waybar",
        "signal": 8
    },

   "custom/weather" : {
        //shows the current weather and forecast
        "tooltip" : true,
        "format" : "{}",
        "interval" : 30,
        "exec" : "python ~/.config/waybar/scripts/waybar-wttr.py",
        "return-type" : "json"
    },

    "custom/laptopwlogout": {
	"format" : "{icon} ",
	"on-click" : "exec wlogout -b 5",
	"tooltip" : false,
	"format-icons": ["οÄë"]
    },


    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "clock": {
        "format": "{:%H:%M %b %e}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}   {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
        "on-scroll-up": "brightnessctl set 1%-",
        "on-scroll-down": "brightnessctl set 1%+",
        "min-length": 6
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "tooltip": false,
        "format": "{icon} {capacity}%",
        "format-charging": "ο΅Π {capacity}%",
        "format-plugged": "ο΅Π {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "tooltip": false,
        "format-muted": "οÄΠ  Muted",
        "on-click": "pamixer -t",
        "on-click-right": "./usr/bin/pavucontrol",
        "on-scroll-up": "pamixer -d 1",
        "on-scroll-down": "pamixer -i 1",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "οÄΞ",
            "hands-free": "οÄΞ",
            "headset": "οÄΞ",
            "phone": "ο²ï",
            "portable": "ο²ï",
            "car": "οÜΙ",
            "default": ["οÄΠ", "οÄß", "οÄ®"]
        }
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ο³Α  {volume}%",
        "format-source-muted": "ο³±    Muted",
        "on-click": "pamixer --default-source -t",
        "on-scroll-up": "pamixer --default-source -d 1",
        "on-scroll-down": "pamixer --default-source -i 1",
        "scroll-step": 5
    },
    
    "temperature": {
        "thermal-zone": 1,
        "format": "{temperatureC}¬ΑC ο΄â",
        "critical-threshold": 80,
        "format-critical": "{temperatureC}¬ΑC ο΄΅"
    },

    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "ο΅Ϊ  {signalStrength}%",
        "format-ethernet": "{ipaddr}/{cidr}",
        "tooltip-format": "{essid} - {ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected βö†",
        "format-alt": "{ifname}:{essid} {ipaddr}/{cidr}"
    },

    "bluetooth": {
	    "format": "οäî {status}",
	    "format-disabled": "", // an empty format will hide the module
	    "format-connected": "οäî {num_connections}",
	    "tooltip-format": "{device_alias}",
	    "tooltip-format-connected": "οäî {device_enumerate}",
	    "tooltip-format-enumerate-connected": "{device_alias}"
    }
}, {
    // WORKSTATION CONFIG

    "layer": "bottom",
    "output": "DP-1",
    "position": "bottom",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 0,
    "modules-left": ["clock", "custom/weather", "hyprland/workspaces"],
    "modules-center": ["custom/os_button", "wlr/taskbar"],
    "modules-right": ["mpris","pulseaudio","pulseaudio#microphone","tray","custom/wlogout"],
    "hyprland/window": {
        "format": "{}"
    },

   "hyprland/workspaces": {

        "disable-scroll": true,
        "on-scroll-up": "hyprctl dispatch workspace -1",
        "on-scroll-down": "hyprctl dispatch workspace +1",
		"format": "[{name}: {windows}]",
		"on-click": "activate",
		"format-icons": {
			"urgent": "ο¹Σ",
			"active": "",
			"default": ""
		},

    	"persistent-workspaces": {
    	         "*": 5
        },

        "window-rewrite-default": "σ±™Μ",
