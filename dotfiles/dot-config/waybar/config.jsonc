		    "title<.*youtube.*>": "οÖΣ", // Windows whose titles contain "youtube"
		    "class<firefox>": "οâ©", // Windows whose classes are "firefox"
		    "class<none>": "r", // Windows whose classes are "firefox"
		    "class<librewolf>": "σΑàΙ", 
		    "class<librewolf> title<.*github.*>": "ο³™", // Windows whose class is "librewolf" and title contains "github". Note that "class" always comes first.
		    "alacritty": "νûï",
		    "ghostty": "νûï", 
            "thunar": "σ±ßΕ", 
		    "code": "σΑ®û",
		    "slack": "νΔΛ",
		    "youtube-music": "σΑéÜ",
            "notion": "νΓà",
		    "title<.* - (.*) - VSCodium>": "codium $1"  // captures part of the window title and formats it into output
	    }
    },

    "custom/weather" : {
        //shows the current weather and forecast
        "tooltip" : true,
        "format" : "{}",
        "interval" : 30,
        "exec" : "python ~/.config/waybar/scripts/waybar-wttr.py",
        "return-type" : "json"
    },

    "custom/wlogout": {
	"format" : "{icon}",
	"on-click" : "exec wlogout -b 5",
	"tooltip" : false,
	"format-icons": ["οÄë"]
    },

    "mpris": {
	    "format": "Playing: {player_icon} <i>{title}</i>",
	    "format-paused": "Paused: {status_icon} {title}",
	    "player-icons": {
	    	"default": "βèΗ",
	    	"mpv": "πüéΒ"
	    },
	    "status-icons": {
	    	"paused": "β•Ε"
	        }
    },


    "custom/wallpaper-engine": {
        "exec": "/usr/bin/dwall -s cliffs >/dev/null 2>&1",
        "interval": 60
    },


    "tray": {
        "icon-size": 18,
        "spacing": 10,
        "icons": {
            "steam": "$HOME/.local/share/icons/hicolor/16x16/apps/steam-waybar.png"
        }
    },

    "clock": {
        "format": "{:%H:%M %b %e}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}   {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
        "on-scroll-up": "brightnessctl set 1%-",
        "on-scroll-down": "brightnessctl set 1%+",
        "min-length": 6
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "tooltip": false,
        "format": "{icon} {capacity}%",
        "format-charging": "ο΅Π {capacity}%",
        "format-plugged": "ο΅Π {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "tooltip": false,
        "format-muted": "οÄΠ  Muted",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click": "if pgrep -x pavucontrol > /dev/null; then \nkillall pavucontrol \nelse \npavucontrol \nfi",
        "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%+",
        "on-scroll-down": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%-",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "οÄΞ",
            "hands-free": "οÄΞ",
            "headset": "οÄΞ",
            "phone": "ο²ï",
            "portable": "ο²ï",
            "car": "οÜΙ",
            "default": ["οÄΠ", "οÄß", "οÄ®"]
        }
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ο³Α  {volume}%",
        "format-source-muted": "ο³±    Muted",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 1%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 1%-",
        "scroll-step": 5
    },
    
    "temperature": {
        "thermal-zone": 1,
        "format": "{temperatureC}¬ΑC ο΄â",
        "critical-threshold": 80,
        "format-critical": "{temperatureC}¬ΑC ο΄΅"
    },

    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "ο΅Ϊ  {signalStrength}%",
        "format-ethernet": "{ipaddr}/{cidr}",
        "tooltip-format": "{essid} - {ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected βö†",
        "format-alt": "{ifname}:{essid} {ipaddr}/{cidr}"
    },

    "bluetooth": {
	    "format": "οäî {status}",
	    "format-disabled": "", // an empty format will hide the module
	    "format-connected": "οäî {num_connections}",
	    "tooltip-format": "{device_alias}",
	    "tooltip-format-connected": "οäî {device_enumerate}",
	    "tooltip-format-enumerate-connected": "{device_alias}"
    }
}, {
